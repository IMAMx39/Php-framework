{% extends 'base.html.twig' %}

{% block title %}Accueil — {{ app.name }}{% endblock %}

{% block content %}
<div style="text-align:center; padding: 4rem 0 2rem;">
    <h1 style="font-size:2.5rem; color:#4f46e5; margin-bottom:1rem;">
        Bienvenue sur <strong>{{ app.name }}</strong> !
    </h1>
    <p style="font-size:1.1rem; color:#64748b; max-width:500px; margin:0 auto 2rem;">
        Ton framework PHP fait maison, inspiré de Symfony.
    </p>
</div>

<div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(220px,1fr)); gap:1.25rem; margin-top:1rem;">

    {% for route in routes %}
    <div style="background:#fff; border:1px solid #e2e8f0; border-radius:.75rem; padding:1.25rem;">
        <span style="
            display:inline-block; padding:.25rem .6rem; border-radius:.375rem;
            font-size:.75rem; font-weight:700; margin-bottom:.75rem;
            background:{% if route.method == 'GET' %}#dbeafe{% elseif route.method == 'POST' %}#dcfce7{% else %}#fef3c7{% endif %};
            color:{% if route.method == 'GET' %}#1e40af{% elseif route.method == 'POST' %}#166534{% else %}#92400e{% endif %};
        ">{{ route.method }}</span>
        <code style="display:block; font-size:.9rem; margin-bottom:.5rem; color:#0f172a;">{{ route.path }}</code>
        <p style="font-size:.85rem; color:#64748b; margin:0;">{{ route.description }}</p>
    </div>
    {% endfor %}

</div>
{% endblock %}
