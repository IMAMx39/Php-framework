APP_NAME=MyApp
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost:8000

# ──────────────────────────────────────────────
#  Base de données
#  Formats supportés :
#    mysql://user:password@127.0.0.1:3306/my_database
#    pgsql://user:password@127.0.0.1:5432/my_database
#    sqlite:////absolute/path/to/db.sqlite
# ──────────────────────────────────────────────

DATABASE_URL=mysql://root:@127.0.0.1:3306/my_database

# ──────────────────────────────────────────────
#  Mailer (optionnel — NullMailer utilisé si vide)
# ──────────────────────────────────────────────

MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME="${APP_NAME}"
