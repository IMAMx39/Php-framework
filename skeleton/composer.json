{
    "name": "imamx39/php-framework-skeleton",
    "description": "Skeleton application for imamx39/php-framework — use with composer create-project.",
    "type": "project",
    "license": "MIT",
    "keywords": ["framework", "php", "skeleton", "mvc"],
    "authors": [
        {
            "name": "IMAMx39",
            "role": "Developer"
        }
    ],
    "require": {
        "php": ">=8.1",
        "imamx39/php-framework": "^1.0",
        "twig/twig": "^3.24"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Migrations\\": "migrations/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test":  "phpunit",
        "serve": "php -S localhost:8000 -t public/",
        "post-create-project-cmd": [
            "@php bin/setup"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
